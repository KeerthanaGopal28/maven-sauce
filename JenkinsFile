pipeline{
   agent any
   tools{
   maven 'maven'
   jdk 'JDK'
   }
   stages{
      stage('Checkout'){
         steps{
          git branch:'main',
          url:'https://github.com/KeerthanaGopal28/maven-sauce.git'
         }     
      }
      stage('Build'){
         steps{
            sh 'mvn clean package'
          }
      }
      stage('Test'){
         steps{
            sh 'mvn test'
         }
      }
      stage('Run Application'){
         steps{
             sh 'java -jar target/maven-app-jenkin-1.0-SNAPSHOT.jar'
         }
      }
   }
   post{
      success{
        echo "Build success"
      }
      failure{
        echo "Build Failure"
      }
   }
} 
  
      
          
